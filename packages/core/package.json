{
  "name": "next-sitecore-ai",
  "version": "0.0.1",
  "description": "AI toolkit for Sitecore JSS on Next.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
 "exports": {
  ".": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  }
},
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sitecore-jss/sitecore-jss-nextjs": ">=22.0.0 <22.7.0",
    "next": ">=14.0.0 <15",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@supabase/supabase-js": "^2.108.2",
    "ai": "^4.3.16",
    "openai": "^6.44.0"
  },
  "devDependencies": {
    "@sitecore-jss/sitecore-jss-nextjs": "~22.6.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.23",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}